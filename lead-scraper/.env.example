# API key de Google Cloud con "Places API (New)" habilitada y facturación activada.
GOOGLE_MAPS_API_KEY=

# Credenciales para entrar al panel (Basic Auth). Déjalas vacías solo en local.
SCRAPER_USER=admin
SCRAPER_PASS=cambia-esto

# Supabase: para guardar los leads en la tabla `prospectos`.
# Usa la SERVICE ROLE key (la tabla tiene RLS sin políticas anon). NUNCA la expongas en el front.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Opcionales
PORT=3000
EMAIL_CONCURRENCY=5
